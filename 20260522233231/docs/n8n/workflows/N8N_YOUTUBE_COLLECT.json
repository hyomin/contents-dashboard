            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "resolution=merge-duplicates,return=minimal"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify($json.videoRows) }}",
        "options": {}
      },
      "id": "node-save-videos",
      "name": "Supabase: 영상 저장",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1860,
        480
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ok: true, workflowKey: 'youtube-collect', platform: 'youtube', message: '수집 완료 ✅', timestamp: new Date().toISOString() } }];"
      },
      "id": "node-done",
      "name": "완료 알림",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
        480
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ ($env.DASHBOARD_API_URL || 'http://host.docker.internal:3000').replace(/\\/$/, '') }}/api/dashboard/notion-sync",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "x-dashboard-api-key", "value": "={{ $env.DASHBOARD_API_SECRET || '' }}" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ workflowKey: 'youtube-collect', platform: 'youtube', summary: $input.first().json }) }}",
        "options": { "timeout": 30000 }
      },
      "id": "node-notion-log-yt",
      "name": "Notion 기록",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2300, 480],
      "continueOnFail": true
    }
