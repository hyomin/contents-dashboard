{
  "name": "티스토리 글 목록 수집 (RSS)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "tistory-collect",
        "responseMode": "lastNode",
        "options": {}
      },
      "id": "node-webhook-tistory-collect",
      "name": "Webhook 수집",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [100, 200],
      "webhookId": "tistory-collect-webhook"
    },
    {
      "parameters": {},
      "id": "node-manual-tistory-collect",
      "name": "수동 실행",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [100, 380]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days",
              "daysInterval": 1
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "id": "node-schedule-tistory-collect",
      "name": "스케줄 (1일마다)",
      "position": [100, 560]
    },
    {
      "parameters": {
        "jsCode": "let mineOnly = false;\ntry {\n  const wh = $('Webhook 수집').all();\n  if (wh.length) {\n    const raw = wh[0].json;\n    const b = raw.body ?? raw;\n    const parsed = typeof b === 'string' ? JSON.parse(b) : b;\n    if (parsed?.mineOnly != null) mineOnly = Boolean(parsed.mineOnly);\n  }\n} catch {}\nconst base = ($env.DASHBOARD_API_URL || 'http://host.docker.internal:3000').replace(/\\/$/, '');\nconst secret = $env.DASHBOARD_API_SECRET || '';\nif (!secret) {\n  return [{ json: {\n    ok: false,\n    skipCall: true,\n    message: 'DASHBOARD_API_SECRET 미설정. .env.local 확인 후 n8n 컨테이너를 재기동하세요.',\n  } }];\n}\nreturn [{ json: {\n  mineOnly,\n  skipCall: false,\n  collectUrl: `${base}/api/dashboard/collect-platform`,\n  apiSecret: secret,\n  source: 'n8n',\n} }];"
      },
      "id": "node-parse-tistory",
      "name": "기준·API 설정",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 380]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "skip",
              "leftValue": "={{ $json.skipCall }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-skip-tistory",
      "name": "설정 오류?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [540, 380]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $json.collectUrl }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-dashboard-api-key",
              "value": "={{ $json.apiSecret }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ platform: 'tistory', mineOnly: $json.mineOnly }) }}",
        "options": {
          "timeout": 300000
        }
      },
      "id": "node-call-tistory-collect",
      "name": "대시보드: 티스토리 글 목록 수집",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [760, 280]
    },
    {
      "parameters": {
        "jsCode": "const collectRaw = $input.first().json;\nfunction parse(j) {\n  if (typeof j === 'string') { try { return JSON.parse(j); } catch { return { message: j.slice(0,300) }; } }\n  if (j?.body && typeof j.body === 'object') return j.body;\n  return j;\n}\nconst collect = parse(collectRaw);\nconst ok = collect?.ok !== false;\nreturn [{ json: {\n  ok,\n  mode: 'n8n',\n  platform: 'tistory',\n  collect: {\n    succeeded: collect?.succeeded ?? 0,\n    failed: collect?.failed ?? 0,\n    total: collect?.total ?? 0,\n    message: collect?.message,\n  },\n  message: ok\n    ? `티스토리 RSS 수집 완료 · ${collect?.succeeded ?? 0}/${collect?.total ?? 0} 채널 성공`\n    : (collect?.error || collect?.message || '수집 실패'),\n  timestamp: new Date().toISOString(),\n} }];"
      },
      "id": "node-done-tistory",
      "name": "완료",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [980, 280]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: {\n  ok: false,\n  mode: 'n8n',\n  message: $input.first().json.message || '설정 오류',\n  timestamp: new Date().toISOString(),\n} }];"
      },
      "id": "node-done-skip-tistory",
      "name": "완료 (설정 오류)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 480]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ ($env.DASHBOARD_API_URL || 'http://host.docker.internal:3000').replace(/\\/$/, '') }}/api/dashboard/notion-sync",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" },
            { "name": "x-dashboard-api-key", "value": "={{ $env.DASHBOARD_API_SECRET || '' }}" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ workflowKey: 'tistory-collect', platform: 'tistory', summary: $input.first().json }) }}",
        "options": { "timeout": 30000 }
      },
      "id": "node-notion-log-tistory",
      "name": "Notion 기록",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 380],
      "continueOnFail": true
    }
  ],
  "connections": {
    "Webhook 수집": {
      "main": [[{ "node": "기준·API 설정", "type": "main", "index": 0 }]]
    },
    "수동 실행": {
      "main": [[{ "node": "기준·API 설정", "type": "main", "index": 0 }]]
    },
