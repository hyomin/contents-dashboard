      "main": [[{ "node": "기준·API 설정", "type": "main", "index": 0 }]]
    },
    "기준·API 설정": {
      "main": [[{ "node": "설정 오류?", "type": "main", "index": 0 }]]
    },
    "설정 오류?": {
      "main": [
        [{ "node": "완료 (설정 오류)", "type": "main", "index": 0 }],
        [{ "node": "대시보드: 티스토리 글 목록 수집", "type": "main", "index": 0 }]
      ]
    },
    "대시보드: 티스토리 글 목록 수집": {
      "main": [[{ "node": "완료", "type": "main", "index": 0 }]]
    },
    "완료": {
      "main": [[{ "node": "Notion 기록", "type": "main", "index": 0 }]]
    },
    "완료 (설정 오류)": {
      "main": [[{ "node": "Notion 기록", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" },
