      "id": "node-http-gen-report",
      "name": "리포트 생성",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "continueOnFail": true,
      "position": [1420, 560]
    },
    {
      "parameters": {
        "jsCode": "const res = $json;\nconst statusCode = res.statusCode ?? res.status ?? 200;\n\nif (statusCode === 409) {\n  return [{ json: {\n    ok: false,\n    alreadyExists: true,\n    message: '오늘 리포트가 이미 생성됐습니다. 건너뜁니다.',\n    statusCode,\n  } }];\n}\n\nconst body = res.body ?? res;\nreturn [{ json: {\n  ok: body.ok !== false,\n  alreadyExists: false,\n  message: body.message ?? '리포트 생성 완료',\n  reportDate: body.reportDate ?? '',\n  itemCount: Array.isArray(body.items) ? body.items.length : 0,\n  statusCode,\n} }];"
      },
      "id": "node-code-report-result",
