      "typeVersion": 1,
      "position": [760, 200]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.settingsUrl }}",
        "options": {}
      },
      "id": "node-http-get-settings",
      "name": "자동 생성 설정 조회",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [760, 460]
    },
    {
      "parameters": {
        "jsCode": "const settings = $json;\nconst config = $('기준·API 설정').first().json;\n\nconst autoEnabled = settings.auto_generate_enabled !== false;\nconst skipUntil = settings.skip_until ?? null;\nconst todayKst = new Date(Date.now() + 9 * 60 * 60 * 1000).toISOString().slice(0, 10);\nconst isSkipped = skipUntil !== null && skipUntil >= todayKst;\n\nconst skipGenerate = !autoEnabled || isSkipped;\nconst skipReason = !autoEnabled\n  ? '자동 생성 비활성화됨'\n  : isSkipped\n  ? `${skipUntil}까지 건너뜀 설정됨`\n  : null;\n\nreturn [{ json: {\n  skipGenerate,\n  skipReason,\n  reportUrl: config.reportUrl,\n  apiSecret: config.apiSecret,\n  todayKst,\n} }];"
      },
      "id": "node-code-check-settings",
      "name": "자동 생성 조건 확인",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [980, 460]
    },
